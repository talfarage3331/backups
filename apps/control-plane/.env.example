# Database connection string (PostgreSQL / Supabase)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Environment mode
NODE_ENV=development

# Control Plane HTTP port (default: 3001)
PORT=3001

# LLM Provider — Claude 3.5 Haiku (Anthropic)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alternative: OpenAI GPT-4o-mini (uncomment and remove ANTHROPIC_API_KEY if preferred)
# OPENAI_API_KEY=your_openai_api_key_here
